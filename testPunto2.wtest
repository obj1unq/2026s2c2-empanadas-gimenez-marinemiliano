import empleados.*

test "Qué hacen los empleados con lo que cobran" {
	
  baigorria.actualizarEmpanadasVendidas(500)
  galvan.sueldo(20000)
  baigorria.actualizarEmpanadasVendidas(300)
  gimenez.pagarA(baigorria)
  gimenez.pagarA(galvan)
  
  baigorria.actualizarEmpanadasVendidas(100)
  gimenez.pagarA(baigorria)
  assert.equals(13500, baigorria.totalCobrado())
  
 	
}